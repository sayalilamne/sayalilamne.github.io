        </div>
        <div class="exp-card__body">
          <ul>
            <li>Contributed to residential and commercial design projects, developing technical drawings, design documentation, and conceptual presentations under senior architectural supervision.</li>
            <li>Engaged in client-facing design reviews and coordinated across disciplines to ensure project delivery and design intent.</li>
          </ul>
        </div>
        <div class="exp-card__more">
          <p class="exp-card__more-label">Find More</p>
          <div class="exp-card__more-links">
            <a class="exp-card__more-link" href="#">Mumbai Projects</a>
            <a class="exp-card__more-link" href="#">Design Portfolio</a>
          </div>
        </div>
      </article>

    </div>
  </div>

  <script is:inline>
    (function () {
      const cards    = document.querySelectorAll('.exp-card');
      const navItems = document.querySelectorAll('.exp-nav-item');

      // Smooth scroll on nav click
      navItems.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = document.getElementById(btn.dataset.target);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
      });

      // Activate card + nav + fade siblings
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;

          cards.forEach(c => {
            const active = c.id === id;
            c.classList.toggle('is-active', active);
            c.style.opacity     = active ? '1'   : '0.18';
            c.style.transform   = active ? 'translateY(0) scale(1)' : 'translateY(10px) scale(0.99)';
          });

          navItems.forEach(n => {
            n.classList.toggle('is-active', n.dataset.target === id);
          });
        });
      }, { threshold: 0.35, rootMargin: '-8% 0px -8% 0px' });

      cards.forEach(c => observer.observe(c));
    })();
  </script>

</body>
</html>

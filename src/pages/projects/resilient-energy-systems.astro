<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Professional Experience — Sayali Lamne</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,300;0,400;0,600;0,700;1,300&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Raleway', sans-serif;
      background: #ffffff;
      color: #111111;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Nav ── */
    .nav { padding: 32px 5%; position: relative; z-index: 10; }
    .back {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 500; color: #db634c;
      text-decoration: none; letter-spacing: 0.06em; text-transform: uppercase;
    }
    .back:hover { text-decoration: underline; }

    /* ── Page header ── */
    .page-header { padding: 0 5% 60px; }
    .page-index {
      font-size: 13px; font-weight: 600; color: #db634c;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px;
    }
    .page-title {
      font-size: clamp(32px, 4.5vw, 54px); font-weight: 700;
      line-height: 1.1; letter-spacing: -0.5px; max-width: 700px;
    }
    .page-divider { border: none; border-top: 1px solid #e8e8e8; margin: 32px 0 0; }

    /* ── Main layout: wider left col (290px = 242 × 1.2) ── */
    .experience-layout {
      display: grid;
      grid-template-columns: 290px 1px 1fr;
      gap: 0;
      padding: 0 5%;
    }

    /* ── Left sticky nav ── */
    .exp-nav {
      position: sticky; top: 80px; align-self: start;
      padding: 48px 28px 48px 0;
    }
    .exp-nav-item {
      display: block; padding: 14px 0; cursor: pointer;
      border: none; background: none; text-align: left; width: 100%;
      transition: all 0.3s ease;
    }
    .exp-nav-item__role {
      font-size: 17px; font-weight: 600; line-height: 1.3; color: #bbb;
      transition: color 0.3s ease;
    }
    .exp-nav-item__org {
      font-size: 14px; font-weight: 400; color: #ccc; margin-top: 4px;
      transition: color 0.3s ease;
    }
    .exp-nav-item__dates {
      font-size: 13px; font-weight: 300; color: #ddd; margin-top: 3px;
      transition: color 0.3s ease;
    }
    .exp-nav-item.is-active .exp-nav-item__role  { color: #db634c; }
    .exp-nav-item.is-active .exp-nav-item__org   { color: #444; }
    .exp-nav-item.is-active .exp-nav-item__dates { color: #888; }
    .exp-nav-item:hover .exp-nav-item__role { color: rgba(219,99,76,0.7); }

    /* ── Center timeline ── */
    .timeline-line {
      width: 1px;
      background: linear-gradient(to bottom, transparent, #e0e0e0 80px, #e0e0e0 calc(100% - 80px), transparent);
    }

    /* ── Right content ── */
    .exp-content { padding: 0 0 0 56px; }

    /* ── Individual experience card ── */
    .exp-card {
      min-height: 100vh; padding: 52px 0 88px;
      display: flex; flex-direction: column; gap: 32px;
      position: relative;
      opacity: 0.2; transform: translateY(20px) scale(0.99);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .exp-card.is-active { opacity: 1; transform: translateY(0) scale(1); }

    /* ── Timeline node — filled circle with white icon ── */
    .exp-card__node {
      position: absolute;
      left: -72px; top: 60px;
      width: 40px; height: 40px;
      border-radius: 50%;
      background: #eee;
      border: 2px solid transparent;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease;
      z-index: 2;
    }
    .exp-card__node svg { width: 18px; height: 18px; }
    .exp-card.is-active .exp-card__node {
      background: #db634c;
      border-color: #db634c;
      transform: scale(1.15);
      box-shadow: 0 0 0 6px rgba(219,99,76,0.15), 0 4px 16px rgba(219,99,76,0.25);
    }

    /* ── Image area ── */
    .exp-card__image {
      width: 100%; aspect-ratio: 16/7;
      background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
      border-radius: 6px; overflow: hidden; position: relative;
      transform: scale(0.98); transition: transform 0.7s ease;
    }
    .exp-card.is-active .exp-card__image { transform: scale(1); }
    .exp-card__image-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      color: #bbb; font-size: 14px; font-weight: 300; letter-spacing: 0.06em;
    }
    .exp-card__image img { width: 100%; height: 100%; object-fit: cover; display: block; }

    /* ── Header ── */
    .exp-card__role {
      font-size: clamp(24px, 3vw, 34px); font-weight: 700;
      line-height: 1.15; letter-spacing: -0.3px; margin-bottom: 8px;
    }
    .exp-card__org { font-size: 17px; font-weight: 600; color: #db634c; margin-bottom: 6px; }
    .exp-card__dates { font-size: 14px; font-weight: 300; color: #888; }

    /* ── Description bullets ── */
    .exp-card__body {
      font-size: 16px; font-weight: 300; line-height: 1.85; color: #444;
    }
    .exp-card__body ul { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .exp-card__body li { padding-left: 20px; position: relative; }
    .exp-card__body li::before {
      content: '';
      position: absolute; left: 0; top: 12px;
      width: 8px; height: 1.5px; background: #db634c;
    }
    .exp-card__body strong { font-weight: 600; color: #111; }

    /* ── Tag chips ── */
    .exp-card__tags {
      display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px;
    }
    .exp-card__tag {
      font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
      text-transform: uppercase; color: #db634c;
      padding: 4px 10px; border: 1px solid rgba(219,99,76,0.3);
      border-radius: 2px; background: rgba(219,99,76,0.04);
    }

    /* ── Find More ── */
    .exp-card__more { border-top: 1px solid #f0f0f0; padding-top: 24px; }
    .exp-card__more-label {
      font-size: 12px; font-weight: 600; color: #db634c;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 14px;
    }
    .exp-card__more-links { display: flex; flex-wrap: wrap; gap: 10px; }
    .exp-card__more-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 500; color: #555;
      text-decoration: none; padding: 7px 16px;
      border: 1px solid #e0e0e0; border-radius: 2px;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .exp-card__more-link:hover {
      border-color: #db634c; color: #db634c; background: rgba(219,99,76,0.04);
    }
    .exp-card__more-link::after { content: '→'; font-size: 12px; }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .experience-layout { grid-template-columns: 1fr; padding: 0 4%; }
      .timeline-line { display: none; }
      .exp-nav {
        position: static; padding: 20px 0;
        display: flex; gap: 10px; overflow-x: auto;
        border-bottom: 1px solid #eee; margin-bottom: 32px;
      }
      .exp-nav-item { flex-shrink: 0; padding: 8px 12px; border: 1px solid #eee; border-radius: 2px; width: auto; }
      .exp-content { padding: 0; }
      .exp-card { min-height: auto; opacity: 1; transform: none; }
      .exp-card__node { display: none; }
    }
  </style>
</head>

---
const title = "Building Performance & Environmental Simulation";
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Sayali Lamne</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;600&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Raleway', sans-serif; background: #fff; color: #111; }
    .back { display: inline-block; margin: 40px 5%; font-size: 14px; color: #db634c; text-decoration: none; letter-spacing: 0.05em; }
    .back:hover { text-decoration: underline; }
    .hero { padding: 80px 5% 120px; }
    .index { font-size: 13px; font-weight: 500; color: #db634c; font-family: system-ui, sans-serif; margin-bottom: 24px; }
    h1 { font-size: clamp(36px, 6vw, 72px); font-weight: 600; line-height: 1.1; letter-spacing: -0.5px; max-width: 800px; }
    .placeholder { margin-top: 80px; padding: 60px; background: #f5f5f5; text-align: center; color: #aaa; font-size: 16px; font-weight: 300; border-radius: 2px; }
  </style>
</head>
<body>
  <a class="back" href="/#projects">← Back to Projects</a>
  <div class="hero">
    <p class="index">04</p>
    <h1>{title}</h1>
    <div class="placeholder">Content coming soon</div>
  </div>
</body>
</html>

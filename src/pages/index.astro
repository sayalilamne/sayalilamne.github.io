---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			body {
				font-family: 'Raleway', system-ui, -apple-system, sans-serif;
			}
		</style>
	</head>
	<body class="min-h-screen bg-white text-gray-800">
		<main class="relative">
			<!-- Hero cover with animated facade GIF background -->
			<section
				class="relative h-[50vh] w-full overflow-hidden"
			>
				<img
					src="/facade-3.gif"
					alt=""
					aria-hidden="true"
					class="absolute inset-0 h-full w-full object-cover object-center opacity-[0.375]"
				/>
				<nav
					class="relative z-10 flex justify-end gap-8 px-6 py-7 text-sm font-light tracking-wide md:gap-14 md:px-14 md:text-base"
				>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Home</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Projects</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Research</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">About me</a>
					<a href="mailto:sayali03lamne@gmail.com" class="text-gray-700 hover:text-[#e35336]">Contacts</a>
				</nav>
			</section>

			<!-- Intro (pulled up so the card overlaps the GIF; no bg so GIF shows around it) -->
			<section class="relative z-10 -mt-32 pb-16 sm:-mt-52 lg:-mt-72">
				<div class="mx-auto max-w-4xl px-4 md:px-6">
					<!-- White card overlapping the GIF: photo left, centered text right -->
					<div
						class="grid bg-white shadow-xl md:grid-cols-[2fr_3fr]"
					>
						<!-- Photo (fills the column edge-to-edge) -->
						<div class="h-full">
							<img
								src="/sayali.png"
								alt="Sayali Lamne"
								class="h-full w-full object-cover grayscale"
							/>
						</div>

						<!-- Text -->
						<div class="flex flex-col justify-center px-6 py-8 text-center md:px-8 md:py-10">
							<p class="text-xl font-light tracking-wide text-gray-400 md:text-2xl">
								<span class="mr-1 align-top text-3xl font-bold text-gray-300">&ldquo;</span>Hi there
							</p>
							<h1 class="mt-3 text-3xl font-extrabold tracking-tight text-black md:text-4xl">
								I'm Sayali Lamne
							</h1>
							<p class="mt-4 text-base font-light tracking-wide text-gray-500 md:text-lg">
								LEED AP | CEM | Program Leadership | Climate Technology
							</p>
							<p class="mx-auto mt-6 max-w-md text-sm leading-relaxed text-gray-600 md:text-base">
								Sustainability &amp; Energy Strategist driving decarbonization, electrification,
								and resilient infrastructure across data centers, mobility, and the built
								environment.<span class="ml-1 align-bottom text-3xl font-bold text-gray-300"
									>&rdquo;</span
								>
							</p>
							<p class="mt-6 text-base font-light tracking-wide text-gray-500 md:text-lg">
								8+ Years Experience | 4+ Research Publications | 20+ Projects
							</p>
						</div>
					</div>

					<!-- Action buttons (filled terracotta), right-aligned -->
					<div class="mt-10 flex flex-wrap justify-end gap-4">
						<a
							href="https://drive.google.com/file/d/12k26JEVy5VCxMNSsf6hkEf0ICvMYvSAe/view?usp=sharing"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#c8442b]"
						>
							Resume
						</a>
						<a
							href="https://heyzine.com/flip-book/a7caad5571.html"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#c8442b]"
						>
							Portfolio
						</a>
						<a
							href="https://www.linkedin.com/in/arslamne"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#c8442b]"
						>
							LinkedIn
						</a>
						<a
							href="https://sayalilamne.github.io/energy-market-analysis/"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#c8442b]"
						>
							GitHub
						</a>
					</div>

					<!-- Contact -->
					<div class="mt-5 text-center">
						<a
							href="mailto:sayali03lamne@gmail.com"
							class="text-sm font-light tracking-wide text-gray-600 hover:text-[#e35336]"
						>
							Contact
						</a>
					</div>
				</div>
			</section>

			<!-- Blueprint crosshair overlay (decorative) -->
			<div class="pointer-events-none absolute inset-x-0 top-0 z-20 h-[520px] opacity-40 lg:h-[740px]">
				<div class="absolute inset-y-0 left-1/2 border-l border-dashed border-gray-400"></div>
				<div
					class="absolute inset-x-0 top-[230px] border-t border-dashed border-gray-400 lg:top-[420px]"
				></div>
			</div>
		</main>
	</body>
</html>

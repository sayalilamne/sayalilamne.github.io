---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			html {
				scroll-behavior: smooth;
			}
			body {
				font-family: 'Raleway', system-ui, -apple-system, sans-serif;
			}
			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
			}
		</style>
		<style>
			/* Intro card typography — sized to match the reference slide */
			.intro-quote {
				font-family: Arial, Helvetica, sans-serif;
				font-size: 50px;
				line-height: 0;
				color: #cfcfcf;
			}
			.intro-greeting {
				font-family: 'Abadi Extra Light', 'Abadi', 'Segoe UI Light', sans-serif;
				font-weight: 200;
				font-size: 30px;
				color: #808080;
			}
			.intro-name {
				font-family: Impact, 'Haettenschweiler', 'Arial Narrow Bold', sans-serif;
				font-weight: normal;
				font-size: 46px;
				color: #000000;
				margin-top: 6px;
				margin-bottom: 22px;
			}
			.intro-credentials {
				font-family: 'Arial Nova Light', Arial, sans-serif;
				font-weight: 300;
				font-size: 19px;
				letter-spacing: 0.5px;
				color: #808080;
				margin-bottom: 28px;
			}
			.intro-bio {
				font-family: 'Aptos Narrow', 'Arial Narrow', Arial, sans-serif;
				font-size: 17px;
				line-height: 1.7;
				color: #5f5f5f;
				max-width: 660px;
			}
			.intro-bio + .intro-bio {
				margin-top: 22px;
			}
			@media (max-width: 768px) {
				.intro-greeting {
					font-size: 24px;
				}
				.intro-name {
					font-size: 36px;
				}
				.intro-credentials {
					font-size: 16px;
				}
				.intro-bio {
					font-size: 15px;
				}
			}

			/* ---- Projects showcase section ---- */
			.projects-section {
				min-height: 100vh;
				background-color: #ffffff;
				width: 100%;
				padding: 100px 24px 120px;
			}
			.projects-inner {
				max-width: 1100px;
				margin: 0 auto;
			}
			.projects-title {
				font-family: 'Raleway', sans-serif;
				font-weight: 600;
				font-size: 56px;
				letter-spacing: -0.5px;
				color: #111111;
				text-align: center;
			}
			.projects-subtitle {
				font-family: 'Raleway', sans-serif;
				font-weight: 300;
				font-size: 19px;
				line-height: 1.6;
				color: #808080;
				text-align: center;
				max-width: 620px;
				margin: 18px auto 0;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 40px;
				margin-top: 72px;
			}
			.project-card {
				display: flex;
				flex-direction: column;
				background-color: #ffffff;
				border: 1px solid #e6e6e6;
				transition:
					transform 0.35s ease,
					border-color 0.35s ease;
			}
			.project-card:hover {
				transform: translateY(-3px);
				border-color: #b8b8b8;
			}
			.project-card__media {
				aspect-ratio: 16 / 10;
				width: 100%;
				background-color: #f2f2f2;
			}
			.project-card__body {
				padding: 28px 30px 34px;
			}
			.project-card__title {
				font-family: 'Raleway', sans-serif;
				font-weight: 600;
				font-size: 24px;
				color: #111111;
				margin: 0;
			}
			.project-card__desc {
				font-family: 'Raleway', sans-serif;
				font-weight: 300;
				font-size: 16px;
				line-height: 1.65;
				color: #808080;
				margin: 12px 0 0;
			}

			/* Scroll-reveal: cards rise into view */
			.reveal {
				opacity: 0;
				transform: translateY(28px);
				transition:
					opacity 0.7s ease,
					transform 0.7s ease;
			}
			.reveal.is-visible {
				opacity: 1;
				transform: none;
			}

			@media (max-width: 768px) {
				.projects-section {
					padding: 72px 20px 88px;
				}
				.projects-title {
					font-size: 40px;
				}
				.projects-grid {
					grid-template-columns: 1fr;
					gap: 28px;
					margin-top: 48px;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.reveal {
					opacity: 1;
					transform: none;
					transition: none;
				}
				.project-card {
					transition: none;
				}
			}
		</style>
	</head>
	<body class="min-h-screen bg-white text-gray-800">
		<main class="relative">
			<!-- Hero cover with animated facade GIF background -->
			<section
				class="relative h-[50vh] w-full overflow-hidden"
			>
				<img
					src="/facade-3.gif"
					alt=""
					aria-hidden="true"
					class="absolute inset-0 h-full w-full object-cover object-top opacity-[0.375]"
				/>
				<nav
					class="relative z-10 flex justify-end gap-8 px-6 py-7 text-sm font-light tracking-wide md:gap-14 md:px-14 md:text-base"
				>
					<a href="#" class="text-gray-700 hover:text-[#DB634C]">Home</a>
					<a href="#projects" class="text-gray-700 hover:text-[#DB634C]">Projects</a>
					<a href="#" class="text-gray-700 hover:text-[#DB634C]">Research</a>
					<a href="#" class="text-gray-700 hover:text-[#DB634C]">About me</a>
					<a href="mailto:sayali03lamne@gmail.com" class="text-gray-700 hover:text-[#DB634C]">Contacts</a>
				</nav>
			</section>

			<!-- Intro (pulled up so the card's center sits on the GIF's bottom edge) -->
			<section class="relative z-10 -mt-32 pb-16 sm:-mt-44 lg:-mt-56">
				<div class="mx-auto px-4" style="max-width: 1100px;">
					<!-- White card: photo left (40%), centered text right (60%); no border, no shadow -->
					<div class="grid grid-cols-1 items-stretch bg-white md:grid-cols-[2fr_3fr]">
						<!-- Photo column: light backing fills to the top edge, portrait bottom-aligned, edge-to-edge -->
						<div class="flex items-end justify-center" style="background-color: #f2f2f2;">
							<img
								src="/portrait.jpg"
								alt="Sayali Lamne"
								class="block self-end object-cover object-bottom grayscale"
							style="width: 440px; height: 600px;"
							/>
						</div>

						<!-- Text column: centered block, pulled left so the paragraphs overlap onto the photo -->
						<div
							class="relative z-10 flex flex-col items-center justify-center text-center md:-ml-15"
							style="padding: 44px 52px 44px 16px;"
						>
							<p class="intro-greeting">
								<span
									class="intro-quote"
									aria-hidden="true"
									style="font-size: 50px; vertical-align: -0.35em; margin-right: 4px;"
									>&ldquo;</span
								>Hi there
							</p>
							<h1 class="intro-name">I'm Sayali Lamne</h1>
							<p class="intro-credentials">
								LEED AP | CEM | Program Leadership | Climate Technology
							</p>
							<p class="intro-bio">
								I'm a Sustainability and Energy Strategist with 8 years of experience leading
								programs across data centers, autonomous vehicles, electric mobility,
								grid-interactive buildings, and energy systems. With a background in
								architecture and certifications as a LEED AP and Certified Energy Manager
								(CEM), I combine technical rigor, systems thinking, and cross-functional
								leadership to transform complex challenges into scalable solutions.
							</p>
							<p class="intro-bio">
								My work focuses on decarbonization, electrification, resilience, and
								operational excellence, helping organizations translate ambitious
								sustainability goals into measurable outcomes through data-driven
								decision-making and strategic execution.<span
									class="intro-quote"
									aria-hidden="true"
									style="font-size: 50px; vertical-align: -0.5em; margin-left: 6px;"
									>&rdquo;</span
								>
							</p>
						</div>
					</div>

					<!-- Action buttons (filled terracotta), right-aligned -->
					<div class="flex flex-wrap justify-end gap-4" style="margin-top: calc(var(--spacing) * 2);">
						<a
							href="https://drive.google.com/file/d/12k26JEVy5VCxMNSsf6hkEf0ICvMYvSAe/view?usp=sharing"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center bg-[#DB634C] px-7 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#C2503A]"
							style="height: 40px;"
						>
							Resume
						</a>
						<a
							href="https://heyzine.com/flip-book/a7caad5571.html"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center bg-[#DB634C] px-7 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#C2503A]"
							style="height: 40px;"
						>
							Portfolio
						</a>
						<a
							href="#projects"
							class="inline-flex items-center bg-[#DB634C] px-7 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#C2503A]"
							style="height: 40px;"
						>
							Projects
						</a>
						<a
							href="https://www.linkedin.com/in/arslamne"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center bg-[#DB634C] px-7 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#C2503A]"
							style="height: 40px;"
						>
							LinkedIn
						</a>
						<a
							href="https://sayalilamne.github.io/energy-market-analysis/"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center bg-[#DB634C] px-7 text-sm font-medium tracking-wide text-white transition-colors hover:bg-[#C2503A]"
							style="height: 40px;"
						>
							GitHub
						</a>
					</div>
				</div>
			</section>

			<!-- Projects showcase: revealed as the hero scrolls away above it -->
			<section id="projects" class="projects-section">
				<div class="projects-inner">
					<h2 class="projects-title reveal">Projects</h2>
					<p class="projects-subtitle reveal">
						Selected work across sustainability, energy systems, climate technology, and
						infrastructure.
					</p>

					<div class="projects-grid">
						<a href="#" class="project-card reveal">
							<div class="project-card__media"></div>
							<div class="project-card__body">
								<h3 class="project-card__title">Sustainability Strategy</h3>
								<p class="project-card__desc">
									Roadmaps and programs that turn ambitious decarbonization goals into measurable,
									organization-wide outcomes.
								</p>
							</div>
						</a>
						<a href="#" class="project-card reveal">
							<div class="project-card__media"></div>
							<div class="project-card__body">
								<h3 class="project-card__title">Energy &amp; Infrastructure</h3>
								<p class="project-card__desc">
									Grid-interactive buildings, electrification, and resilient systems engineered for
									performance at scale.
								</p>
							</div>
						</a>
						<a href="#" class="project-card reveal">
							<div class="project-card__media"></div>
							<div class="project-card__body">
								<h3 class="project-card__title">Data Centers</h3>
								<p class="project-card__desc">
									Efficiency, siting, and operational strategy for high-density compute and critical
									infrastructure.
								</p>
							</div>
						</a>
						<a href="#" class="project-card reveal">
							<div class="project-card__media"></div>
							<div class="project-card__body">
								<h3 class="project-card__title">Research &amp; Publications</h3>
								<p class="project-card__desc">
									Analysis and writing on energy markets, climate technology, and the systems shaping
									the transition.
								</p>
							</div>
						</a>
						<a href="#" class="project-card reveal">
							<div class="project-card__media"></div>
							<div class="project-card__body">
								<h3 class="project-card__title">Design &amp; Visualization</h3>
								<p class="project-card__desc">
									Architecture-rooted visual storytelling that makes complex systems clear and
									compelling.
								</p>
							</div>
						</a>
					</div>
				</div>
			</section>
		</main>

		<script is:inline>
			(function () {
				const items = document.querySelectorAll('.reveal');
				if (!('IntersectionObserver' in window)) {
					items.forEach((el) => el.classList.add('is-visible'));
					return;
				}
				const io = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								io.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
				);
				items.forEach((el, i) => {
					el.style.transitionDelay = Math.min(i * 80, 320) + 'ms';
					io.observe(el);
				});
			})();
		</script>
	</body>
</html>

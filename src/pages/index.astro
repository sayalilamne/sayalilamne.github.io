					<a href="#projects" class="text-gray-700 hover:text-[#DB634C]">Projects</a>
					<a href="#" class="text-gray-700 hover:text-[#DB634C]">Research</a>
					<a href="#" class="text-gray-700 hover:text-[#DB634C]">About me</a>
					<a href="mailto:sayali03lamne@gmail.com" class="text-gray-700 hover:text-[#DB634C]">Contacts</a>
				</nav>
			</section>

			<!-- Intro (pulled up so the card's center sits on the GIF's bottom edge) -->
			<section class="relative z-10 -mt-32 pb-16 sm:-mt-44 lg:-mt-56">
				<div class="mx-auto px-4" style="max-width: 1100px;">
					<!-- White card: photo left (40%), centered text right (60%); no border, no shadow -->
					<div class="grid grid-cols-1 items-stretch bg-white md:grid-cols-[2fr_3fr]">
						<!-- Photo column: light backing fills to the top edge, portrait bottom-aligned, edge-to-edge -->
						<div class="flex items-end justify-center" style="background-color: #f2f2f2;">
							<img
								src="/portrait.jpg"
								alt="Sayali Lamne"

---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
	</head>
	<body class="min-h-screen bg-white text-gray-800">
		<!-- Thin top accent bar -->
		<div class="h-1.5 w-full bg-neutral-900"></div>

		<main class="relative">
			<!-- Hero cover with animated facade GIF background -->
			<section
				class="h-[300px] w-full bg-cover bg-center md:h-[470px]"
				style="background-image: url('/facade-2.gif');"
			>
				<nav class="flex justify-end gap-8 px-6 py-6 text-sm md:gap-12 md:px-12 md:text-base">
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Home</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Projects</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">Research</a>
					<a href="#" class="text-gray-700 hover:text-[#e35336]">About me</a>
				</nav>
			</section>

			<!-- Intro -->
			<section class="bg-white pb-16">
				<div class="mx-auto max-w-6xl px-4 md:px-8">
					<!-- White card overlapping the GIF: photo left, centered text right -->
					<div
						class="relative z-10 -mt-36 grid items-center bg-white shadow-xl md:-mt-52 md:grid-cols-[2fr_3fr]"
					>
						<!-- Photo -->
						<div class="flex items-center justify-center bg-neutral-100 p-4 md:p-6">
							<img
								src="/sayali.png"
								alt="Sayali Lamne"
								class="w-2/3 object-cover grayscale md:w-full"
							/>
						</div>

						<!-- Text -->
						<div class="px-6 py-8 text-center md:px-10 md:py-12">
							<p class="text-xl text-gray-400">
								<span class="mr-1 align-top">&ldquo;</span>Hi there
							</p>
							<h1 class="mt-2 text-3xl font-bold text-black md:text-4xl">I'm Sayali Lamne</h1>
							<p class="mt-4 text-base text-gray-500 md:text-lg">
								LEED AP | CEM | Program Leadership | Climate Technology
							</p>
							<p class="mx-auto mt-6 max-w-md text-sm leading-relaxed text-gray-600">
								Sustainability &amp; Energy Strategist driving decarbonization, electrification,
								and resilient infrastructure across data centers, mobility, and the built
								environment.<span class="ml-1 align-bottom text-xl text-gray-300">&rdquo;</span>
							</p>
							<p class="mt-6 text-base text-gray-500 md:text-lg">
								8+ Years Experience | 4+ Research Publications | 20+ Projects
							</p>
						</div>
					</div>

					<!-- Action buttons (filled terracotta) -->
					<div class="mt-10 flex flex-wrap justify-center gap-4">
						<a
							href="https://drive.google.com/file/d/12k26JEVy5VCxMNSsf6hkEf0ICvMYvSAe/view?usp=sharing"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#c8442b]"
						>
							Resume
						</a>
						<a
							href="https://heyzine.com/flip-book/a7caad5571.html"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#c8442b]"
						>
							Portfolio
						</a>
						<a
							href="https://www.linkedin.com/in/arslamne"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#c8442b]"
						>
							LinkedIn
						</a>
						<a
							href="https://sayalilamne.github.io/energy-market-analysis/"
							target="_blank"
							rel="noopener noreferrer"
							class="bg-[#e35336] px-7 py-2.5 text-sm font-medium text-white transition-colors hover:bg-[#c8442b]"
						>
							GitHub
						</a>
					</div>

					<!-- Contact -->
					<div class="mt-5 text-center">
						<a
							href="mailto:sayali03lamne@gmail.com"
							class="text-sm text-gray-600 hover:text-[#e35336]"
						>
							Contact
						</a>
					</div>
				</div>
			</section>

			<!-- Blueprint crosshair overlay (decorative) -->
			<div class="pointer-events-none absolute inset-x-0 top-0 z-20 h-[560px] opacity-40 md:h-[760px]">
				<div class="absolute inset-y-0 left-1/2 border-l border-dashed border-gray-400"></div>
				<div
					class="absolute inset-x-0 top-[280px] border-t border-dashed border-gray-400 md:top-[430px]"
				></div>
			</div>
		</main>
	</body>
</html>

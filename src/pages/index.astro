---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			html {
				scroll-behavior: smooth;
			}
			body {
				font-family: 'Raleway', system-ui, -apple-system, sans-serif;
			}
			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
			}
		</style>
		<style>
			/* Intro card typography — sized to match the reference slide */
			.intro-quote {
				font-family: Arial, Helvetica, sans-serif;
				font-size: 50px;
				line-height: 0;
				color: #cfcfcf;
			}
			.intro-greeting {
				font-family: 'Abadi Extra Light', 'Abadi', 'Segoe UI Light', sans-serif;
				font-weight: 200;
				font-size: 30px;
				color: #808080;
			}
			.intro-name {
				font-family: Impact, 'Haettenschweiler', 'Arial Narrow Bold', sans-serif;
				font-weight: normal;
				font-size: 46px;
				color: #000000;
				margin-top: 6px;
				margin-bottom: 22px;
			}
			.intro-credentials {
				font-family: 'Arial Nova Light', Arial, sans-serif;
				font-weight: 300;
				font-size: 19px;
				letter-spacing: 0.5px;
				color: #808080;
				margin-bottom: 28px;
			}
			.intro-bio {
				font-family: 'Aptos Narrow', 'Arial Narrow', Arial, sans-serif;
				font-size: 17px;
				line-height: 1.7;
				color: #5f5f5f;
				max-width: 660px;
			}
			.intro-bio + .intro-bio {
				margin-top: 22px;
			}
			@media (max-width: 768px) {
				.intro-greeting {
					font-size: 24px;
				}
				.intro-name {
					font-size: 36px;
				}
				.intro-credentials {
					font-size: 16px;
				}
				.intro-bio {
					font-size: 15px;
				}
			}

			/* ---- Scroll cue at the bottom of the hero ---- */
			.scroll-cue {
				margin-top: 40px;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 8px;
				color: #b3b3b3;
				transition: color 0.3s ease;
			}
			.scroll-cue:hover {
				color: #8a8a8a;
			}
			.scroll-cue__label {
				font-family: 'Raleway', sans-serif;
				font-size: 13px;
				font-weight: 300;
				letter-spacing: 2px;
				text-transform: uppercase;
			}
			.scroll-cue__arrows {
				display: flex;
				flex-direction: column;
				align-items: center;
				line-height: 0.55;
				animation: scrollFloat 1.9s ease-in-out infinite;
			}
			.scroll-cue__arrows svg {
				width: 16px;
				height: 16px;
			}
			@keyframes scrollFloat {
				0%,
				100% {
					transform: translateY(0);
				}
				50% {
					transform: translateY(6px);
				}
			}

			/* ---- Projects showcase section ---- */
			/* ---- Projects showcase section ---- */
			.projects-section {
				min-height: 100vh;
				background-color: #ffffff;
				width: 100%;
				padding: 110px 4% 120px;
			}
			/* Two-column layout: head on the left, grid on the right — centered */
			.projects-inner {
				display: grid;
				grid-template-columns: 3fr 7fr;
				gap: 0 48px;
				align-items: start;
				max-width: 100%;
				margin-left: auto;
				margin-right: auto;
			}
			.projects-head {
				position: sticky;
				top: 80px;
				padding-top: 8px;
			}
			.projects-title {
				font-family: 'Raleway', sans-serif;
				font-weight: 600;
				font-size: 60px;
				letter-spacing: -0.5px;
				color: #111111;
				text-align: left;
				margin: 0;
			}
			.projects-subtitle {
				font-family: 'Raleway', sans-serif;
				font-weight: 300;
				font-size: 19px;
				line-height: 1.6;
				color: #808080;
				text-align: left;
				max-width: 640px;
				margin: 20px 0 0;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 48px 28px;
				margin-top: 0;
			}
			.cat-card {
				display: flex;
				flex-direction: column;
				background: transparent;
				border: none;
				text-align: left;
				cursor: pointer;
			}
			/* Wrapper: leaves 28px on the left for the absolutely-positioned number */
			.cat-card__top {
				position: relative;
				padding-left: 28px;
			}
			/* Number: anchored to the bottom-left corner of the image, outside it */
			.cat-card__index {
				position: absolute;
				bottom: 0;
				left: 0;
				font-family: system-ui, sans-serif;
				font-weight: 500;
				font-size: 13px;
				line-height: 1;
				color: #db634c;
			}
			/* Image area fills the right portion of the wrapper */
			.cat-card__media {
				position: relative;
				width: 100%;
				aspect-ratio: 4 / 3;
				background-color: #f2f2f2;
				overflow: hidden;
			}
			.cat-card__fill {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				background-color: #f2f2f2;
				background-size: cover;
				background-position: center;
				transform: scale(1);
				transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
			}
			/* Text area: full width, left edge aligns with the number */
			.cat-card__text {
				padding-top: 14px;
			}
			.cat-card__title {
				font-family: 'Raleway', sans-serif;
				font-weight: 600;
				font-size: 18px;
				line-height: 1.3;
				color: #111111;
				margin: 0;
			}
			.cat-card__desc {
				font-family: 'Raleway', sans-serif;
				font-weight: 300;
				font-size: 16px;
				line-height: 1.6;
				color: #808080;
				margin: 8px 0 0;
			}
			/* Hover / active: zoom image, highlight text */
			.cat-card {
				text-decoration: none;
				transition: none;
			}
			.cat-card__title,
			.cat-card__desc {
				transition: color 0.3s ease, font-size 0.3s ease;
			}
			.cat-card:hover .cat-card__fill,
			.cat-card.is-active .cat-card__fill {
				transform: scale(1.1);
			}
			.cat-card:hover .cat-card__title,
			.cat-card.is-active .cat-card__title {
				color: #db634c;
				font-size: 20px;
			}
			.cat-card:hover .cat-card__desc,
			.cat-card.is-active .cat-card__desc {
				color: #444444;
				font-size: 17px;
			}

			/* Scroll-reveal: heading + cards rise together, Apple-style ease-out */
			.reveal {
				opacity: 0;
				transform: translateY(60px);
				transition:
					opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
					transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
			}
			.reveal.is-visible {
				opacity: 1;
				transform: none;
			}

			/* 3-up → 2-up → 1-up as the viewport narrows */
			@media (max-width: 1100px) {
				.projects-inner {
					grid-template-columns: 220px 1fr;
					gap: 0 40px;
				}
			}
			@media (max-width: 860px) {
				.projects-inner {
					grid-template-columns: 1fr;
				}
				.projects-head {
					position: static;
					margin-bottom: 40px;
				}
			}
			@media (max-width: 880px) {
				.projects-grid {
					grid-template-columns: repeat(2, 1fr);
					gap: 44px 36px;
				}
			}
			@media (max-width: 768px) {
				.projects-section {
					padding: 80px 24px 80px;
				}
				.projects-title {
					font-size: 42px;
				}
				.projects-grid {
					margin-top: 0;
				}
			}
			@media (max-width: 560px) {
				.projects-grid {
					grid-template-columns: 1fr;
					gap: 40px;
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.reveal {
					opacity: 1;
					transform: none;
					transition: none;
				}
				.cat-card,
				.scroll-cue__arrows {
					transition: none;
					animation: none;
				}
			}
		</style>
	</head>
	<body class="min-h-screen bg-white text-gray-800">
		<main class="relative">

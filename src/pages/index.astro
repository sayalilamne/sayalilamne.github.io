---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
	</head>
	<body class="min-h-screen bg-white text-gray-800">
		<!-- Hero cover with animated facade GIF background (compact) -->
		<section
			class="relative h-44 w-full bg-cover bg-center md:h-56"
			style="background-image: url('/facade-2.gif');"
		>
			<nav class="flex justify-end gap-8 px-8 py-6 text-sm md:text-base">
				<a href="#" class="font-medium text-white drop-shadow hover:text-[#e35336]">Home</a>
				<a href="#" class="font-medium text-white drop-shadow hover:text-[#e35336]">Projects</a>
				<a href="#" class="font-medium text-white drop-shadow hover:text-[#e35336]">Published Research</a>
			</nav>
		</section>

		<!-- Intro: photo overlaps up onto the GIF; centered text panel overlaps the photo -->
		<section class="w-full bg-white">
			<div class="mx-auto max-w-6xl px-4 md:px-8">
				<div class="flex flex-col md:flex-row md:items-start">
					<!-- Photo (lifted up to overlap the GIF) -->
					<div class="relative z-0 -mt-20 md:-mt-32 md:w-2/5 md:shrink-0">
						<img
							src="/sayali.png"
							alt="Sayali Lamne"
							class="mx-auto w-2/3 object-cover grayscale md:w-full"
						/>
					</div>

					<!-- Centered text panel (stays below the GIF, overlaps the photo) -->
					<div
						class="relative z-10 -mt-6 bg-white px-6 py-8 text-center shadow-xl md:-ml-16 md:mt-10 md:w-3/5 md:px-12 md:py-10"
					>
						<!-- opening quotation mark -->
						<span class="block text-5xl leading-none text-gray-300">&ldquo;</span>

						<h1 class="mt-2 text-2xl font-bold text-gray-800 md:text-3xl">
							Hi, I'm Sayali Lamne.
						</h1>
						<p class="mt-3 text-lg font-light text-gray-500 md:text-xl">
							Driving Sustainable Innovation Through Technology, Data, and Energy Systems
						</p>
						<p class="mt-3 text-xs italic text-gray-500 md:text-sm">
							Sustainability &amp; Energy Strategist | LEED AP, CEM | Decarbonization,
							Electrification, Data Centers, Grid-Interactive Buildings, and Climate Technology
						</p>

						<p class="mt-5 text-sm leading-relaxed text-gray-600">
							I'm a Sustainability Strategist and Energy Expert with 8 years of experience driving
							programs at the intersection of technology, energy, and the built environment. My work
							spans data centers, autonomous vehicles, electric mobility, grid-interactive buildings,
							and energy systems, with a focus on resilience, decarbonization, electrification,
							energy optimization, and operational excellence. With a background in architecture and
							certifications as a LEED Accredited Professional (LEED AP) and Certified Energy Manager
							(CEM), I combine systems thinking, analytical rigor, and cross-functional leadership to
							turn complex challenges into scalable solutions.
						</p>

						<p class="mt-4 text-sm leading-relaxed text-gray-600">
							I thrive on translating strategic vision into execution, collaborating across teams to
							deliver meaningful business, operational, and sustainability outcomes. Whether
							optimizing infrastructure, scaling innovative programs, or navigating emerging
							technologies, I am driven by continuous growth, intellectual curiosity, and the
							opportunity to create lasting impact.
						</p>

						<!-- closing quotation mark -->
						<span class="mt-1 block text-right text-5xl leading-none text-gray-300">&rdquo;</span>
					</div>
				</div>

				<!-- Social link buttons (hover -> terracotta red), centered -->
				<div class="mt-10 flex flex-wrap justify-center gap-4 pb-16">
					<a
						href="https://www.linkedin.com/in/arslamne"
						target="_blank"
						rel="noopener noreferrer"
						class="border border-gray-800 px-6 py-2 text-sm font-medium text-gray-800 transition-colors hover:border-[#e35336] hover:bg-[#e35336] hover:text-white"
					>
						LinkedIn
					</a>
					<a
						href="https://sayalilamne.github.io/energy-market-analysis/"
						target="_blank"
						rel="noopener noreferrer"
						class="border border-gray-800 px-6 py-2 text-sm font-medium text-gray-800 transition-colors hover:border-[#e35336] hover:bg-[#e35336] hover:text-white"
					>
						GitHub
					</a>
					<a
						href="https://drive.google.com/file/d/12k26JEVy5VCxMNSsf6hkEf0ICvMYvSAe/view?usp=sharing"
						target="_blank"
						rel="noopener noreferrer"
						class="border border-gray-800 px-6 py-2 text-sm font-medium text-gray-800 transition-colors hover:border-[#e35336] hover:bg-[#e35336] hover:text-white"
					>
						Resume PDF
					</a>
				</div>
			</div>
		</section>
	</body>
</html>

---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Sayali Lamne</title>
	</head>
	<body class="min-h-screen bg-[#d8d8d8] text-gray-800">
		<!-- Yellow top cover (placeholder for a future GIF) -->
		<section class="relative min-h-[40vh] w-full bg-[#fbecaa]">
			<nav class="flex justify-end gap-8 px-8 py-6 text-sm md:text-base">
				<a href="#" class="text-gray-700 hover:text-black">Home</a>
				<a href="#" class="text-gray-700 hover:text-black">Projects</a>
				<a href="#" class="text-gray-700 hover:text-black">Published Research</a>
			</nav>
		</section>

		<!-- Gray lower band -->
		<section class="min-h-[55vh] w-full pb-12">
			<!-- White intro card overlapping the yellow / gray seam -->
			<div class="relative z-10 mx-auto -mt-24 max-w-5xl bg-white shadow-md">
				<div class="grid items-stretch md:grid-cols-2">
					<!-- Photo -->
					<div class="bg-white p-6 md:p-8">
						<img
							src="/sayali.png"
							alt="Sayali Lamne"
							class="h-full w-full object-cover grayscale"
						/>
					</div>

					<!-- Bio -->
					<div class="flex flex-col justify-center px-6 py-8 text-center md:px-10 md:py-10">
						<p class="text-gray-400">
							<span class="mr-1 align-top text-2xl">&ldquo;</span>Hi there
						</p>
						<h1 class="mt-1 text-2xl font-bold text-gray-800 md:text-3xl">I'm Sayali Lamne</h1>
						<p class="mt-3 text-xl text-gray-400 md:text-2xl">
							I like to define myself as someone who is always in the
							<em>process of progress</em>.
						</p>

						<p class="mt-6 text-sm leading-relaxed text-gray-500">
							After graduating from Rachana Sansad's Academy of Architecture, Mumbai in 2018
							&amp; gaining 2 years of experience in high-rise residential projects, this pursuit
							of constantly evolving myself and my fascination for sustainability in the built
							environment led me to my current program of Master of Science in Sustainable Design
							at Carnegie Mellon University. I specialize in designing innovative solutions to
							generate high-performance buildings and leading organizations toward a greener future.
						</p>

						<p class="mt-4 text-sm leading-relaxed text-gray-500">
							Over the years, I have broadened my skillset while collaborating on diverse-scale
							projects with cutting-edge technologies. I believe my versatility and hardworking
							attitude can be a great asset to a cohort.
							<span class="ml-1 align-bottom text-2xl text-gray-400">&rdquo;</span>
						</p>
					</div>
				</div>
			</div>

			<!-- Footer links -->
			<footer class="mx-auto mt-6 max-w-5xl px-2">
				<div class="flex flex-wrap gap-8 text-sm text-gray-700 md:text-base">
					<a href="#" class="hover:text-black">Resume</a>
					<a href="#" class="hover:text-black">Design Portfolio</a>
					<a href="#" class="hover:text-black">LinkedIn</a>
					<a href="#" class="hover:text-black">Github</a>
					<a href="#" class="hover:text-black">Contact Me</a>
				</div>
			</footer>
		</section>
	</body>
</html>
